rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    // Replace with your admin account's UID
    // (Firebase console → Authentication → Users → "User UID" column)
    function isAdmin() {
      return request.auth != null
        && request.auth.uid == "PASTE_YOUR_ADMIN_UID_HERE";
    }

    // Bill-calculator tariff rates. Public can read (the calculator needs
    // them); only the admin can change them. Tools themselves are defined in
    // code (js/tools.js), so there is no writable "tools" collection anymore.
    match /tariffs/{docId} {
      allow read: if true;
      allow write: if isAdmin();
    }

    // Everything else: locked
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
